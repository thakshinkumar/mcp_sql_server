# Database Configuration
MSSQL_SERVER=localhost\SQLEXPRESS
MSSQL_DATABASE=testdb
MSSQL_WINDOWS_AUTH=true
# MSSQL_USER=your_username
# MSSQL_PASSWORD=your_password
MSSQL_ENCRYPT=false

# If you don't have SQL Server installed, enable offline mode:
# MSSQL_OFFLINE=true

# LLM Configuration - OpenAI
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-actual-openai-api-key-here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=500


# Speech Recognition (Optional - for voice input)
SPEECH_PROVIDER=azure
# SPEECH_API_KEY=your_azure_speech_key
SPEECH_REGION=eastus
SPEECH_LANGUAGE=en-US

# Reinforcement Learning Configuration
RL_ENABLED=true
RL_LEARNING_RATE=0.1
RL_DISCOUNT_FACTOR=0.9
RL_EPSILON=0.1
RL_EPSILON_DECAY=0.995
RL_MIN_EPSILON=0.01

# Optimizer Configuration
OPTIMIZER_NUM_CANDIDATES=3
OPTIMIZER_TIMEOUT=30
OPTIMIZER_COST_WEIGHT=0.5
OPTIMIZER_LATENCY_WEIGHT=0.5
